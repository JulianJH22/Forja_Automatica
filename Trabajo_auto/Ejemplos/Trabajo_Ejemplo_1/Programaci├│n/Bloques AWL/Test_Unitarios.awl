FUNCTION "UT_CNC" : Void
TITLE = Test unitario UP_CNC
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
//Test unitario para el CNC.
//
//¿Cómo ejecutar el test unitario? Definir todos los parámetros de la UP_CNC y llamar al test desde el OB1.

BEGIN
NETWORK
TITLE = Llamada a UP_CNC
//La unidad productiva está activa constantemente, por lo que basta con llamarla para que funcione.
      CALL "UP_CNC", "UT_UP_CNC_DB"
      (  start                       := "start" , 
         emer                        := "ut_emer" , 
         rearme                      := "ut_rearme" , 
         cong                        := "ut_cong" , 
         lapiz                       := "cnc1_lapiz" , 
         sacapuntas                  := "cnc1_sacapuntas" , 
         escuadra                    := "cnc1_escuadra" , 
         cartabon                    := "cnc1_cartabon" , 
         home                        := "cnc1_home" , 
         tmax_cnc_lapiz              := s5t#10s , 
         temp_max                    := "cnc1_temp" , 
         cnc_lapiz                   := "cnc1_cnc_lapiz" , 
         cnc_sacapuntas              := "cnc1_cnc_sacapuntas" , 
         cnc_escuadra                := "cnc1_cnc_escuadra" , 
         cnc_cartabon                := "cnc1_cnc_cartabon" , 
         bit_standby                 := "cnc1_b_standby" , 
         bit_ocupacion               := "cnc1_b_ocupacion" , 
         bit_error_tiempo_lapiz      := "cnc1_bdt_lapiz" , 
         bit_error_tiempo_sacapuntas := "cnc1_bdt_sacapuntas" , 
         bit_error_tiempo_escuadra   := "cnc1_bdt_escuadra" , 
         bit_error_tiempo_cartabon   := "cnc1_bdt_cartabon" , 
         bit_error_config_lapiz      := "cnc1_bdc_lapiz" , 
         bit_error_config_sacapuntas := "cnc1_bdc_sacapuntas" , 
         bit_error_config_escuadra   := "cnc1_bdc_escuadra" , 
         bit_error_config_cartabon   := "cnc1_bdc_cartabon" , 
         bit_emer                    := "cnc1_b_emer"
      );
END_FUNCTION

FUNCTION "UT_Palets_Vacios" : Void
TITLE = Test unitario palets vacíos
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

BEGIN
NETWORK
TITLE = Llamada a la unidad productiva UP_Palets_Vacios
      CALL "UP_Palets_Vacios", "UT_UP_Palets_Vacios_DB"
      (  start                       := "start" , 
         emer                        := "ut_emer" , 
         rearme                      := "ut_rearme" , 
         cong                        := "ut_cong" , 
         hraw                        := "pa_hraw" , 
         LO_LIM                      := "datosProduccion".LO_LIM , 
         HI_LIM                      := "datosProduccion".HI_LIM , 
         hmin                        := "datosProduccion".hmin , 
         hmax                        := "datosProduccion".hmax , 
         recoger_pila                := "pa_recoger_pila" , 
         pila_saturada               := "pa_pila_saturada" , 
         error_medida                := "pa_error_medida" , 
         h_real                      := "pa_hreal" , 
         "h>hmin"                    := "pa_h>hmin" , 
         "h>hmax"                    := "pa_h>hmax" , 
         "h<hmin"                    := "pa_h<hmin"
      );
END_FUNCTION

