FUNCTION "UT_SFC_Cilindro" : Void
TITLE = Test unitario maniobra SFC_Cilindro
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
//Test unitario de SFC_Cilindro. 
//Es necesario probarla dentro de un grafcet para asegurarse que los bits de maniobra y de error síncrono funcionan bien.
//Los parámetros que no pertenecen a la maniobra son los siguientes:
//- x0: estado inicial.
//- m1: bit de maniobra (determina cuándo está activa la maniobra).
//- x2: estado final (tras terminar la maniobra).
//- x10: estados de error síncrono.
//- r1: receptividad entre x0 y m1.
//- r2: receptividad entre x2 y x0.
//- rearme: receptividad entre x10 y x0.
//
//¿Cómo ejecutar el test unitario? Se definen los parámetros indicados anteriormente y los parámetros de la maniobra. Luego se llama al FC.

BEGIN
NETWORK
TITLE = x0 -> m1
      U "ut_x0";
      U "ut_r1";
      S "ut_m1"               ;//Bit de maniobra
      R "ut_x0";
NETWORK
TITLE = Llamada a la maniobra
//Como se trata de un test unitario, no se distingue entre estados de error síncrono por tiempo y por mala configuración inicial. 
//El tiempo de error se definiría en un bloque de datos, pero para realizar el test basta con indicar un valor cualquiera y ver que temporiza adecuadamente.
      U "ut_m1";

      SPBN _man;

      CALL "SFC_Cilindro", "UT_SFC_Cilindro_DB"
      (  sini                        := "ut_sini" , 
         sfin                        := "ut_sfin" , 
         reset                       := "ut_reset" , 
         tiempo_error                := s5t#10s , 
         temp_error                  := "ut_temp" , 
         bit_fin                     := "ut_bdf" , 
         bit_error_tiempo            := "ut_bdt" , 
         bit_error_config            := "ut_bdc" , 
         bit_ocupacion               := "ut_bdo" , 
         actuador                    := "ut_actuador1"
      );


      U "ut_bdt";
      S "ut_x10";
      R "ut_m1";

      U "ut_bdc";
      S "ut_x10";
      R "ut_m1";

      U "ut_bdf";
      S "ut_x2";
      R "ut_m1";

_man:      NOP 0;
NETWORK
TITLE = x2 -> x0
//Vuelta al estado inicial
      U "ut_x2";
      U "ut_r2";
      S "ut_x0";
      R "ut_x2";
NETWORK
TITLE = x10 -> x0
//Rearme del error síncrono
      U "ut_x10";
      U "ut_rearme";
      S "ut_x0";
      R "ut_x10";
END_FUNCTION

FUNCTION "UT_SFC_Programa" : Void
TITLE = Test unitario maniobra SFC_Programa
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
//Test unitario de SFC_Programa. 
//Es necesario probarla dentro de un grafcet para asegurarse que los bits de maniobra y de error síncrono funcionan bien.
//Los parámetros que no pertenecen a la maniobra son los siguientes:
//- x0: estado inicial.
//- m1: bit de maniobra (determina cuándo está activa la maniobra).
//- x2: estado final (tras terminar la maniobra).
//- x10: estados de error síncrono.
//- r1: receptividad entre x0 y m1.
//- r2: receptividad entre x2 y x0.
//- rearme: receptividad entre x10 y x0.
//
//¿Cómo ejecutar el test unitario? Se definen los parámetros indicados anteriormente y los parámetros de la maniobra. Luego se llama al FC.

BEGIN
NETWORK
TITLE = x0 -> m1
      U "ut_x0";
      U "ut_r1";
      S "ut_m1"               ;//Bit de maniobra
      R "ut_x0";
NETWORK
TITLE = Llamada a la maniobra
//Como se trata de un test unitario, no se distingue entre estados de error síncrono por tiempo y por mala configuración inicial. 
//El tiempo de error se definiría en un bloque de datos, pero para realizar el test basta con indicar un valor cualquiera y ver que temporiza adecuadamente.
      U "ut_m1";

      SPBN _man;

      CALL "SFC_Programa", "UT_SFC_Programa_DB"
      (  sensor1                     := "ut_s1" , 
         sensor2                     := "ut_s2" , 
         reset                       := "ut_reset" , 
         tiempo_error                := s5t#10s , 
         temp_error                  := "ut_temp" , 
         bit_fin                     := "ut_bdf" , 
         bit_error_tiempo            := "ut_bdf" , 
         bit_error_config            := "ut_bdc" , 
         bit_ocupacion               := "ut_bdo" , 
         actuador1                   := "ut_actuador1"
      );

      U "ut_bdt";
      S "ut_x10";
      R "ut_m1";

      U "ut_bdc";
      S "ut_x10";
      R "ut_m1";

      U "ut_bdf";
      S "ut_x2";
      R "ut_m1";

_man:      NOP 0;
NETWORK
TITLE = x2 -> x0
//Vuelta al estado inicial
      U "ut_x2";
      U "ut_r2";
      S "ut_x0";
      R "ut_x2";
NETWORK
TITLE = x10 -> x0
//Rearme del error síncrono
      U "ut_x10";
      U "ut_rearme";
      S "ut_x0";
      R "ut_x10";
END_FUNCTION

